{
  "name": "felix-agent-docker",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "form-data": "4.0.6",
    "undici": "6.27.0",
    "vite": "7.3.6"
  },
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "dev": "tsx src/index.ts",
    "dev:web": "npm --prefix web run dev",
    "build:web": "npm --prefix web ci && npm --prefix web run build",
    "build:server": "tsc -p tsconfig.build.json",
    "build": "npm run build:web && npm run build:server",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "^2.1.161",
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@azure/cosmos": "^4.3.0",
    "@openai/codex": "^0.133.0",
    "@slack/bolt": "^4.7.3",
    "discord.js": "^14.18.0",
    "docx": "^9.7.1",
    "ioredis": "^5.4.2",
    "mongodb": "^6.12.0",
    "mysql2": "^3.11.0",
    "opencode-ai": "^1.17.3",
    "pg": "^8.13.0",
    "pptxgenjs": "^4.0.1",
    "ws": "^8.18.3",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@inquirer/prompts": "^8.5.2",
    "@types/node": "^22.13.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3",
    "vitest": "^3.2.7"
  }
}
