{
  "name": "felix-agent-docker",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "dev": "tsx src/index.ts",
    "dev:web": "npm --prefix web run dev",
    "build:web": "npm --prefix web install && npm --prefix web run build",
    "build:server": "tsc -p tsconfig.build.json",
    "build": "npm run build:web && npm run build:server",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "^2.1.161",
    "@openai/codex": "^0.133.0",
    "@slack/bolt": "^4.7.3",
    "discord.js": "^14.18.0",
    "opencode-ai": "^1.17.3",
    "ws": "^8.18.3",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@inquirer/prompts": "^8.5.2",
    "@types/node": "^22.13.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3",
    "vitest": "^3.0.7"
  }
}
