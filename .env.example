# Felix runtime
# Root for the source-extensible workspace layout.
WORKSPACE_DIR=./workspace
CONFIG_DIR=./config
HEALTH_PORT=3000
SOURCE=mattermost

# Owner console
# Shared secret used by the internal owner login form.
OWNER_UI_SECRET=change-me

# Optional secret file path. Defaults to /run/secrets/.env when present.
SECRET_ENV_FILE=/run/secrets/.env

# Codex / OpenAI
CODEX_BIN=codex
CODEX_MODEL=gpt-5.4-mini
CODEX_BYPASS_SANDBOX=true
CODEX_TIMEOUT_SECONDS=1800

# Mattermost
MATTERMOST_URL=
MATTERMOST_TOKEN=
MATTERMOST_BOT_USER_ID=
MATTERMOST_BOT_USERNAME=
MATTERMOST_BOT_DISPLAY=Felix
MATTERMOST_OWNER_USER_ID=
MATTERMOST_OWNER_DISPLAY=Owner

# OpenAI auth
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_ORGANIZATION=
OPENAI_PROJECT=
