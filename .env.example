# Felix Agent configuration
# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit secrets to this example file.

# ── Owner Console ─────────────────────────────────
# Shared secret used to log into the owner console (REQUIRED).
OWNER_UI_SECRET=change-me
# Set true when the owner console is served through an HTTPS reverse proxy.
OWNER_UI_SECURE_COOKIE=false

# ── Docker User ──────────────────────────────────
# Match the host user that owns workspace/ so the container can write there.
UID=1000
GID=1000

# ── Harness (LLM backend) ─────────────────────────
# codex       = Codex CLI by OpenAI (default).
# opencode    = Opencode CLI, model-agnostic.
# claude-code = Claude Code CLI by Anthropic.
HARNESS=codex

# -- Codex harness --
# Path to the Codex binary.
CODEX_BIN=codex

# Codex model name (e.g. gpt-5.4-mini, gpt-5.4).
CODEX_MODEL=gpt-5.4-mini
# Cheaper model for background tasks (memory ingestion, wiki linting).
# Defaults to CODEX_MODEL when unset.
# CODEX_MODEL_FOR_MEMORIZING=

# Bypass Codex sandbox restrictions.
CODEX_BYPASS_SANDBOX=true

# Reasoning effort for models that support it (low | medium | high).
CODEX_REASONING_EFFORT=high

# -- Opencode harness --
# Path to the Opencode binary.
OPENCODE_BIN=opencode

# Opencode model (format: provider/model).
# Use opencode/... for opencode.ai routing; use deepseek/... for direct DeepSeek API.
# deepseek/ prefix uses DEEPSEEK_API_KEY directly (no opencode.ai billing).
OPENCODE_MODEL=opencode/deepseek-v4-flash-free
# Cheaper model for background tasks (memory ingestion, wiki linting).
# Defaults to OPENCODE_MODEL when unset.
# OPENCODE_MODEL_FOR_MEMORIZING=

# Opencode variant (reasoning effort: low | medium | high).
OPENCODE_VARIANT=high

# API key for Opencode provider.
OPENCODE_API_KEY=

# API key for OpenRouter provider.
OPENROUTER_API_KEY=

# API key for DeepSeek models (used as DEEPSEEK_API_KEY env var by opencode).
DEEPSEEK_API_KEY=

# -- Claude Code harness --
# Path to the Claude Code binary.
CLAUDE_CODE_BIN=claude

# Claude Code model (alias: sonnet, opus, haiku, fable or full model ID).
CLAUDE_CODE_MODEL=sonnet
# Cheaper model for background tasks (memory ingestion, wiki linting).
# Defaults to CLAUDE_CODE_MODEL when unset.
# CLAUDE_CODE_MODEL_FOR_MEMORIZING=

# ── 9router Override ─────────────────────────────
# Optional portable override for the active harness.
# When enabled, Felix keeps HARNESS as codex/opencode/claude-code but routes
# key, base URL, and model through 9router. Enabling also surfaces the bundled
# 9router skill to the agent; it stays hidden while this is false.
NINEROUTER_ENABLED=false
NINEROUTER_KEY=
NINEROUTER_MODEL=
# Cheaper model for background tasks (memory ingestion, wiki linting).
# Overrides per-harness memorizing models when 9router is enabled.
# Defaults to NINEROUTER_MODEL when unset.
# NINEROUTER_MODEL_FOR_MEMORIZING=

# Bare gateway base (no /v1). Codex/Opencode append /v1 for the OpenAI API;
# Claude Code appends /v1/messages for the Anthropic API.
NINEROUTER_URL=

# ── OpenAI Auth (shared by Codex harness) ─────────
# For codex harness: use API key OR OAuth (not both).
# OAuth: run `npm run setup` and select "oauth" auth method.
# The setup wizard stores the auth JSON in OPENAI_CODEX_AUTH_JSON below.
# API key auth:
OPENAI_API_KEY=
# OAuth auth (populated by setup wizard, stored as single-quoted JSON):
# OPENAI_CODEX_AUTH_JSON='{"auth_mode":"chatgpt",...}'
OPENAI_BASE_URL=
OPENAI_ORGANIZATION=
OPENAI_PROJECT=

# ── Anthropic Auth (Claude Code harness) ──────────
# API key for Anthropic (required for the claude-code harness).
ANTHROPIC_API_KEY=

# ── Source: Mattermost ────────────────────────────
# Leave all vars blank to disable this source.
MATTERMOST_URL=https://mattermost.example.com
MATTERMOST_BOT_TOKEN=
MATTERMOST_BOT_USERNAME=
MATTERMOST_BOT_DISPLAY=Felix
# Find your User ID: Enter MATTERMOST_OWNER_USERNAME below, setup will auto-lookup via API
MATTERMOST_OWNER_USER_ID=
MATTERMOST_OWNER_USERNAME=
MATTERMOST_OWNER_DISPLAY=Owner

# ── Source: Discord ───────────────────────────────
# Leave blank to disable this source.
# REQUIRES "Message Content Intent" enabled in the Discord Developer Portal
# under Bot → Privileged Gateway Intents.
DISCORD_BOT_TOKEN=
# Find your User ID: Enable Developer Mode, then right-click name → Copy User ID
DISCORD_OWNER_USER_ID=
DISCORD_OWNER_DISPLAY=Owner

# ── Source: Slack ─────────────────────────────────
# Leave blank to disable this source.
# Uses Socket Mode — no public HTTP endpoint required.
# Required bot scopes: channels:history, groups:history, im:history,
#   mpim:history, chat:write, reactions:write, reactions:read, files:read, users:read.
# App-Level Token must have the connections:write scope.
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
# Find your User ID: Click your name → View profile → ⋯ → Copy member ID
SLACK_OWNER_USER_ID=
SLACK_OWNER_DISPLAY=Owner

# ── Source: WhatsApp (via wacli) ──────────────────
# Leave WHATSAPP_BOT_NAME blank to disable this source.
# Requires wacli paired as a WhatsApp Web linked device
# (run setup wizard to pair, or `wacli auth --store <workspace>/runtime/wacli`).
# WHATSAPP_BOT_NAME must use only letters, digits, and underscores (e.g. "Felix_Bot").
WHATSAPP_BOT_NAME=
# Optional comma-separated short aliases for @mention (e.g. "f,F,lix" allows @f, @F, @lix).
# Leave blank to require the full @BotName.
WHATSAPP_BOT_ALIASES=
# Owner's WhatsApp JID (e.g. 1234567890@s.whatsapp.net).
# Leave blank if the bot uses a dedicated number; set to your JID if
# you and the bot share the same WhatsApp number.
WHATSAPP_OWNER_JID=
WHATSAPP_OWNER_DISPLAY=Owner

# ── Source: Telegram ───────────────────────────────
# Leave TELEGRAM_BOT_TOKEN blank to disable this source.
# Create a bot via @BotFather on Telegram and copy the token here.
# Uses long-polling by default — no public URL required.
TELEGRAM_BOT_TOKEN=
# Bot's numeric user ID (auto-detected from Bot API if not set).
# TELEGRAM_BOT_USER_ID=
# Your Telegram numeric user ID (for permission requests).
# Find it: send /start to @userinfobot on Telegram.
TELEGRAM_OWNER_USER_ID=
TELEGRAM_OWNER_DISPLAY=Owner
# Optional secret token for webhook validation (only needed for webhook mode).
# TELEGRAM_WEBHOOK_SECRET=

# ── Owner Notification Routing ─────────────────────
# Route ALL permission/approval notifications to one channel.
# Leave blank to send notifications to the same channel as the event.
# Valid: mattermost | discord | slack | whatsapp | telegram (e.g. whatsapp)
OWNER_CHANNEL=

# ── Database Skill ─────────────────────────────────
# Encryption key for database connection credentials (auto-generated during setup).
DB_ENCRYPTION_KEY=

# ── Token Usage Monitoring ─────────────────────────
# IANA timezone for usage day/week/month boundaries in the owner console
# (e.g. "Asia/Jakarta", "America/New_York"). Defaults to UTC.
USAGE_TZ=UTC
