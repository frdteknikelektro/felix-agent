# Felix Agent configuration
# Copy this file to config/.env and fill in your values.
# config/.env is git-ignored — never commit secrets to this example file.

# ── Runtime ───────────────────────────────────────
# Root directory for runtime data (threads, sessions, skills, approvals).
WORKSPACE_DIR=./workspace

# Directory for local .env overrides.
CONFIG_DIR=./config

# HTTP port for the owner console and /healthz endpoint.
HEALTH_PORT=3000

# Path to a separate secrets file (Docker mounts /run/secrets/.env here).
SECRET_ENV_FILE=/run/secrets/.env

# ── Owner Console ─────────────────────────────────
# Shared secret used to log into the owner console (REQUIRED).
OWNER_UI_SECRET=change-me

# ── Harness (LLM backend) ─────────────────────────
# codex    = Codex CLI by OpenAI (default).
# opencode = Opencode CLI, model-agnostic.
HARNESS=codex

# -- Codex harness --
# Path to the Codex binary.
CODEX_BIN=codex

# Codex model name (e.g. gpt-5.4-mini, gpt-5.4).
CODEX_MODEL=gpt-5.4-mini

# Bypass Codex sandbox restrictions.
CODEX_BYPASS_SANDBOX=true

# Timeout in seconds for each Codex turn.
CODEX_TIMEOUT_SECONDS=1800

# Reasoning effort for models that support it (low | medium | high).
CODEX_REASONING_EFFORT=high

# -- Opencode harness --
# Path to the Opencode binary.
OPENCODE_BIN=opencode

# Opencode model (format: provider/model).
# Use opencode/... for opencode.ai routing; use deepseek/... for direct DeepSeek API.
# deepseek/ prefix uses DEEPSEEK_API_KEY directly (no opencode.ai billing).
OPENCODE_MODEL=deepseek/deepseek-v4-flash

# Opencode variant (optional).
OPENCODE_VARIANT=

# API key for Opencode provider.
OPENCODE_API_KEY=

# API key for DeepSeek models (used as DEEPSEEK_API_KEY env var by opencode).
DEEPSEEK_API_KEY=

# ── OpenAI Auth (shared by Codex harness) ─────────
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_ORGANIZATION=
OPENAI_PROJECT=

# ── Source: Mattermost ────────────────────────────
# Leave all vars blank to disable this source.
MATTERMOST_URL=https://mattermost.example.com
MATTERMOST_TOKEN=
MATTERMOST_BOT_USER_ID=
MATTERMOST_BOT_USERNAME=
MATTERMOST_BOT_DISPLAY=Felix
MATTERMOST_OWNER_USER_ID=
MATTERMOST_OWNER_DISPLAY=Owner

# ── Source: Discord ───────────────────────────────
# Leave blank to disable this source.
# REQUIRES "Message Content Intent" enabled in the Discord Developer Portal
# under Bot → Privileged Gateway Intents.
DISCORD_TOKEN=
DISCORD_BOT_USER_ID=
DISCORD_OWNER_USER_ID=
DISCORD_OWNER_DISPLAY=Owner

# ── Source: Slack ─────────────────────────────────
# Leave blank to disable this source.
# Uses Socket Mode — no public HTTP endpoint required.
# Required bot scopes: channels:history, groups:history, im:history,
#   mpim:history, chat:write, reactions:write, files:read, users:read.
# App-Level Token must have the connections:write scope.
SLACK_TOKEN=
SLACK_APP_TOKEN=
SLACK_BOT_USER_ID=
SLACK_OWNER_USER_ID=
SLACK_OWNER_DISPLAY=Owner
